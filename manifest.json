{
    "manifest_version": 3,
    "name": "ClearTube",
    "version": "1.0",
    "description": "Take back your YouTube homepage. ClearTube hides the algorithm-driven feed and puts a clean search bar front and center.",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["*://www.youtube.com/*"],
            "js": ["content.js"],
            "css": ["style.css"]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
